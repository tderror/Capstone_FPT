# DarkHotel Backend - Environment Variables

# Google Cloud Credentials (Required for Vertex AI)
# Run: gcloud auth application-default login
# Then set the path to the generated credentials file:
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\YOUR_USER\AppData\Roaming\gcloud\application_default_credentials.json

# Google Cloud Project (Required)
# Get from: https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT=your_project_id_here
GOOGLE_CLOUD_LOCATION=us-central1

# Model Configuration (Optional)
MODEL_NAME=gemini-2.5-pro

# Qdrant Vector DB Path (v7 with enriched knowledge base)
QDRANT_DB_PATH=./qdrant_db_v7
